<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="generator" content="{{ generator }}">
  <title>{{ chart_title }}</title>
  <style>
    /* ------------------------------------------------------------------ */
    /* Reset & base                                                        */
    /* ------------------------------------------------------------------ */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html, body {
      height: 100%;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                   Helvetica, Arial, sans-serif;
      background-color: #f5f7fa;
      color: #333;
    }

    /* ------------------------------------------------------------------ */
    /* Page layout                                                         */
    /* ------------------------------------------------------------------ */
    .page-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 2rem 1rem;
    }

    /* ------------------------------------------------------------------ */
    /* Chart card                                                          */
    /* ------------------------------------------------------------------ */
    .chart-card {
      background: #ffffff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.09),
                  0 1px 4px  rgba(0, 0, 0, 0.06);
      padding: 2rem 2.5rem 2.5rem;
      width: 100%;
      {% if responsive %}
      max-width: 1000px;
      {% else %}
      max-width: {{ canvas_width + 80 }}px;
      {% endif %}
    }

    /* ------------------------------------------------------------------ */
    /* Chart header                                                        */
    /* ------------------------------------------------------------------ */
    .chart-header {
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .chart-header h1 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1a202c;
      letter-spacing: -0.02em;
      line-height: 1.3;
    }

    .chart-header .chart-type-badge {
      display: inline-block;
      margin-top: 0.4rem;
      padding: 0.2rem 0.65rem;
      background: #edf2ff;
      color: #4263eb;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border-radius: 999px;
    }

    /* ------------------------------------------------------------------ */
    /* Canvas container                                                    */
    /* ------------------------------------------------------------------ */
    .canvas-container {
      position: relative;
      width: 100%;
      {% if not responsive %}
      height: {{ canvas_height }}px;
      {% endif %}
    }

    {% if responsive %}
    .canvas-container canvas {
      width: 100% !important;
      height: auto !important;
    }
    {% else %}
    .canvas-container canvas {
      width: {{ canvas_width }}px;
      height: {{ canvas_height }}px;
    }
    {% endif %}

    /* ------------------------------------------------------------------ */
    /* Footer                                                              */
    /* ------------------------------------------------------------------ */
    .chart-footer {
      margin-top: 1.25rem;
      text-align: center;
      font-size: 0.72rem;
      color: #a0aec0;
    }

    .chart-footer a {
      color: #a0aec0;
      text-decoration: none;
    }

    .chart-footer a:hover {
      color: #718096;
      text-decoration: underline;
    }

    /* ------------------------------------------------------------------ */
    /* Responsive breakpoints                                              */
    /* ------------------------------------------------------------------ */
    @media (max-width: 600px) {
      .chart-card {
        padding: 1.25rem 1rem 1.5rem;
        border-radius: 8px;
      }

      .chart-header h1 {
        font-size: 1.15rem;
      }
    }
  </style>
</head>
<body>
  <div class="page-wrapper">
    <div class="chart-card">
      <div class="chart-header">
        <h1>{{ chart_title }}</h1>
        <span class="chart-type-badge">{{ chart_type }}</span>
      </div>

      <div class="canvas-container">
        <canvas id="chart-canvas" role="img" aria-label="{{ chart_title }}"></canvas>
      </div>

      <footer class="chart-footer">
        Generated by
        <a href="https://github.com/example/chart_genie" target="_blank" rel="noopener noreferrer">
          chart_genie
        </a>
        &mdash; powered by
        <a href="https://www.chartjs.org/" target="_blank" rel="noopener noreferrer">
          Chart.js
        </a>
      </footer>
    </div>
  </div>

  <!-- Chart.js CDN -->
  <script src="{{ chartjs_cdn_url }}"></script>

  <script>
    (function () {
      "use strict";

      // ----------------------------------------------------------------
      // Chart configuration injected by chart_genie renderer
      // ----------------------------------------------------------------
      var chartConfig = {{ chartjs_config_json | safe }};

      // ----------------------------------------------------------------
      // Canvas setup
      // ----------------------------------------------------------------
      var canvas = document.getElementById("chart-canvas");
      if (!canvas) {
        console.error("chart_genie: canvas element not found.");
        return;
      }

      var ctx = canvas.getContext("2d");
      if (!ctx) {
        console.error("chart_genie: cannot get 2D context from canvas.");
        return;
      }

      // ----------------------------------------------------------------
      // Ensure Chart.js loaded
      // ----------------------------------------------------------------
      if (typeof Chart === "undefined") {
        var errorMsg = document.createElement("p");
        errorMsg.style.cssText = "color:#e53e3e;text-align:center;padding:2rem;font-weight:600;";
        errorMsg.textContent = "Chart.js failed to load. Check your internet connection.";
        canvas.parentNode.replaceChild(errorMsg, canvas);
        return;
      }

      // ----------------------------------------------------------------
      // Render chart
      // ----------------------------------------------------------------
      try {
        var chart = new Chart(ctx, chartConfig);
      } catch (err) {
        console.error("chart_genie: Chart.js failed to render:", err);
        var errDiv = document.createElement("p");
        errDiv.style.cssText = "color:#e53e3e;text-align:center;padding:2rem;font-weight:600;";
        errDiv.textContent = "Failed to render chart: " + err.message;
        canvas.parentNode.replaceChild(errDiv, canvas);
      }
    })();
  </script>
</body>
</html>
